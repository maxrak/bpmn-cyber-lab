<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_AntiPattern" targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_AntiPattern">
    <bpmn:participant id="Pool_1" name="Anti-Pattern A: Start Events Multipli Ambigui" processRef="Process_1" />
    <bpmn:participant id="Pool_2" name="Anti-Pattern B: Processo Senza End Event" processRef="Process_2" />
    <bpmn:participant id="Pool_3" name="Anti-Pattern C: End Events Indistinguibili" processRef="Process_3" />
  </bpmn:collaboration>

  <!-- PROCESSO 1: Due None Start Event identici → ambiguità su quale trigger usare -->
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:startEvent id="Start1_Manual" name="Avvio Manuale">
      <bpmn:outgoing>Flow_1a</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="Start1_Auto" name="Avvio Automatico">
      <bpmn:outgoing>Flow_1b</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task1_Elabora" name="Elabora Richiesta">
      <bpmn:incoming>Flow_1a</bpmn:incoming>
      <bpmn:incoming>Flow_1b</bpmn:incoming>
      <bpmn:outgoing>Flow_1c</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End1" name="Fine">
      <bpmn:incoming>Flow_1c</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Ann1">
      <bpmn:text>PROBLEMA: Due None Start Event identici convergono sullo stesso task. Non esiste distinzione semantica: quando usare l'uno e quando l'altro?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc1a" sourceRef="Ann1" targetRef="Start1_Manual" />
    <bpmn:association id="Assoc1b" sourceRef="Ann1" targetRef="Start1_Auto" />
    <bpmn:sequenceFlow id="Flow_1a" sourceRef="Start1_Manual" targetRef="Task1_Elabora" />
    <bpmn:sequenceFlow id="Flow_1b" sourceRef="Start1_Auto" targetRef="Task1_Elabora" />
    <bpmn:sequenceFlow id="Flow_1c" sourceRef="Task1_Elabora" targetRef="End1" />
  </bpmn:process>

  <!-- PROCESSO 2: Il flusso termina su un Task senza End Event esplicito -->
  <bpmn:process id="Process_2" isExecutable="false">
    <bpmn:startEvent id="Start2" name="Avvia Processo">
      <bpmn:outgoing>Flow_2a</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task2a" name="Ricevi Input">
      <bpmn:incoming>Flow_2a</bpmn:incoming>
      <bpmn:outgoing>Flow_2b</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task2b" name="Elabora Dati">
      <bpmn:incoming>Flow_2b</bpmn:incoming>
      <bpmn:outgoing>Flow_2c</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task2c" name="Salva Risultato">
      <bpmn:incoming>Flow_2c</bpmn:incoming>
      <!-- ANTI-PATTERN: nessun outgoing → nessun End Event -->
    </bpmn:task>
    <bpmn:textAnnotation id="Ann2">
      <bpmn:text>PROBLEMA: Il token si ferma qui senza End Event. Il processo è completato? Bloccato? Il motore BPMN non lo sa.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc2" sourceRef="Ann2" targetRef="Task2c" />
    <bpmn:sequenceFlow id="Flow_2a" sourceRef="Start2" targetRef="Task2a" />
    <bpmn:sequenceFlow id="Flow_2b" sourceRef="Task2a" targetRef="Task2b" />
    <bpmn:sequenceFlow id="Flow_2c" sourceRef="Task2b" targetRef="Task2c" />
  </bpmn:process>

  <!-- PROCESSO 3: Gateway senza nome, uscite senza etichette, End Events identici -->
  <bpmn:process id="Process_3" isExecutable="false">
    <bpmn:startEvent id="Start3" name="Avvia Processo">
      <bpmn:outgoing>Flow_3a</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task3" name="Valuta Richiesta">
      <bpmn:incoming>Flow_3a</bpmn:incoming>
      <bpmn:outgoing>Flow_3b</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW3" name="">
      <!-- ANTI-PATTERN: gateway senza nome, condizioni assenti -->
      <bpmn:incoming>Flow_3b</bpmn:incoming>
      <bpmn:outgoing>Flow_3c</bpmn:outgoing>
      <bpmn:outgoing>Flow_3d</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End3a" name="Fine">
      <!-- ANTI-PATTERN: stesso nome dell'altro end event -->
      <bpmn:incoming>Flow_3c</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End3b" name="Fine">
      <!-- ANTI-PATTERN: stesso nome dell'altro end event -->
      <bpmn:incoming>Flow_3d</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Ann3">
      <bpmn:text>PROBLEMA: Gateway senza nome; uscite senza etichette; entrambi gli End Event si chiamano "Fine". Impossibile capire gli esiti possibili.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc3" sourceRef="Ann3" targetRef="GW3" />
    <bpmn:sequenceFlow id="Flow_3a" sourceRef="Start3" targetRef="Task3" />
    <bpmn:sequenceFlow id="Flow_3b" sourceRef="Task3" targetRef="GW3" />
    <bpmn:sequenceFlow id="Flow_3c" sourceRef="GW3" targetRef="End3a" />
    <bpmn:sequenceFlow id="Flow_3d" sourceRef="GW3" targetRef="End3b" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_AntiPattern">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_AntiPattern">

      <!-- ===== POOL 1 ===== -->
      <bpmndi:BPMNShape id="Pool_1_di" bpmnElement="Pool_1" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="920" height="220" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start1_Manual_di" bpmnElement="Start1_Manual"
          bioc:stroke="#c0392b" color:border-color="#c0392b"
          bioc:fill="#fadbd8" color:background-color="#fadbd8">
        <dc:Bounds x="222" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="202" y="195" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start1_Auto_di" bpmnElement="Start1_Auto"
          bioc:stroke="#c0392b" color:border-color="#c0392b"
          bioc:fill="#fadbd8" color:background-color="#fadbd8">
        <dc:Bounds x="222" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="197" y="255" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task1_Elabora_di" bpmnElement="Task1_Elabora">
        <dc:Bounds x="330" y="150" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="End1_di" bpmnElement="End1">
        <dc:Bounds x="532" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="541" y="215" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Ann1_di" bpmnElement="Ann1">
        <dc:Bounds x="620" y="125" width="420" height="65" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1a_di" bpmnElement="Flow_1a">
        <di:waypoint x="258" y="170" />
        <di:waypoint x="294" y="180" />
        <di:waypoint x="330" y="185" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_1b_di" bpmnElement="Flow_1b">
        <di:waypoint x="258" y="230" />
        <di:waypoint x="294" y="215" />
        <di:waypoint x="330" y="205" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_1c_di" bpmnElement="Flow_1c">
        <di:waypoint x="450" y="190" />
        <di:waypoint x="532" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Assoc1a_di" bpmnElement="Assoc1a">
        <di:waypoint x="620" y="152" />
        <di:waypoint x="258" y="162" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Assoc1b_di" bpmnElement="Assoc1b">
        <di:waypoint x="620" y="178" />
        <di:waypoint x="258" y="232" />
      </bpmndi:BPMNEdge>

      <!-- ===== POOL 2 ===== -->
      <bpmndi:BPMNShape id="Pool_2_di" bpmnElement="Pool_2" isHorizontal="true">
        <dc:Bounds x="160" y="320" width="920" height="200" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start2_di" bpmnElement="Start2">
        <dc:Bounds x="202" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="183" y="445" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task2a_di" bpmnElement="Task2a">
        <dc:Bounds x="290" y="380" width="110" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task2b_di" bpmnElement="Task2b">
        <dc:Bounds x="455" y="380" width="110" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task2c_di" bpmnElement="Task2c"
          bioc:stroke="#d35400" color:border-color="#d35400"
          bioc:fill="#fdebd0" color:background-color="#fdebd0">
        <dc:Bounds x="620" y="380" width="110" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Ann2_di" bpmnElement="Ann2">
        <dc:Bounds x="760" y="377" width="285" height="65" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_2a_di" bpmnElement="Flow_2a">
        <di:waypoint x="238" y="420" />
        <di:waypoint x="290" y="420" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2b_di" bpmnElement="Flow_2b">
        <di:waypoint x="400" y="420" />
        <di:waypoint x="455" y="420" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2c_di" bpmnElement="Flow_2c">
        <di:waypoint x="565" y="420" />
        <di:waypoint x="620" y="420" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Assoc2_di" bpmnElement="Assoc2">
        <di:waypoint x="760" y="415" />
        <di:waypoint x="730" y="420" />
      </bpmndi:BPMNEdge>

      <!-- ===== POOL 3 ===== -->
      <bpmndi:BPMNShape id="Pool_3_di" bpmnElement="Pool_3" isHorizontal="true">
        <dc:Bounds x="160" y="540" width="920" height="210" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start3_di" bpmnElement="Start3">
        <dc:Bounds x="202" y="630" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="183" y="673" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task3_di" bpmnElement="Task3">
        <dc:Bounds x="290" y="608" width="110" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW3_di" bpmnElement="GW3" isMarkerVisible="true"
          bioc:stroke="#d35400" color:border-color="#d35400"
          bioc:fill="#fdebd0" color:background-color="#fdebd0">
        <dc:Bounds x="455" y="623" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="End3a_di" bpmnElement="End3a"
          bioc:stroke="#c0392b" color:border-color="#c0392b"
          bioc:fill="#fadbd8" color:background-color="#fadbd8">
        <dc:Bounds x="572" y="600" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="581" y="643" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="End3b_di" bpmnElement="End3b"
          bioc:stroke="#c0392b" color:border-color="#c0392b"
          bioc:fill="#fadbd8" color:background-color="#fadbd8">
        <dc:Bounds x="572" y="665" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="581" y="708" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Ann3_di" bpmnElement="Ann3">
        <dc:Bounds x="640" y="597" width="400" height="65" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_3a_di" bpmnElement="Flow_3a">
        <di:waypoint x="238" y="648" />
        <di:waypoint x="290" y="648" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3b_di" bpmnElement="Flow_3b">
        <di:waypoint x="400" y="648" />
        <di:waypoint x="455" y="648" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3c_di" bpmnElement="Flow_3c">
        <di:waypoint x="505" y="637" />
        <di:waypoint x="538" y="618" />
        <di:waypoint x="572" y="618" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3d_di" bpmnElement="Flow_3d">
        <di:waypoint x="505" y="660" />
        <di:waypoint x="538" y="683" />
        <di:waypoint x="572" y="683" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Assoc3_di" bpmnElement="Assoc3">
        <di:waypoint x="640" y="630" />
        <di:waypoint x="505" y="648" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
