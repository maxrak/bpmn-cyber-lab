<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_MessageEvents" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:message id="Message_OrderRequest" name="Richiesta Ordine" />
  <bpmn:message id="Message_OrderConfirmation" name="Conferma Ordine" />
  <bpmn:message id="Message_PaymentInfo" name="Info Pagamento" />
  <bpmn:message id="Message_ShipmentNotice" name="Notifica Spedizione" />
  <bpmn:message id="Message_CancelOrder" name="Annulla Ordine" />
  <bpmn:collaboration id="Collaboration_MessageEvents">
    <bpmn:participant id="Participant_Customer" name="Cliente" processRef="Process_Customer" />
    <bpmn:participant id="Participant_Seller" name="Venditore" processRef="Process_Seller" />
    <bpmn:messageFlow id="Flow_Msg_1" sourceRef="Event_SendOrder" targetRef="Event_ReceiveOrder" />
    <bpmn:messageFlow id="Flow_Msg_2" sourceRef="Event_SendConfirmation" targetRef="Event_ReceiveConfirmation" />
    <bpmn:messageFlow id="Flow_Msg_3" sourceRef="Event_SendPayment" targetRef="Event_ReceivePayment" />
    <bpmn:messageFlow id="Flow_Msg_4" sourceRef="Event_SendShipment" targetRef="Event_ReceiveShipment" />
    <bpmn:messageFlow id="Flow_Msg_5" sourceRef="Event_SendCancel" targetRef="Boundary_CancelOrder" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Customer" isExecutable="false">
    <bpmn:startEvent id="Start_Customer" name="Cliente vuole ordinare">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_PrepareOrder" name="Prepara Ordine">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateThrowEvent id="Event_SendOrder" name="Invia Richiesta">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_OrderRequest" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Event_ReceiveConfirmation" name="Attendi Conferma">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_OrderConfirmation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_ReviewOrder" name="Rivedi Ordine">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Accept" name="Accetta?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_6_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateThrowEvent id="Event_SendPayment" name="Invia Pagamento">
      <bpmn:incoming>Flow_6_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_PaymentInfo" />
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_Customer" targetRef="Task_PrepareOrder" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_PrepareOrder" targetRef="Event_SendOrder" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Event_SendOrder" targetRef="Event_ReceiveConfirmation" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Event_ReceiveConfirmation" targetRef="Task_ReviewOrder" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ReviewOrder" targetRef="Gateway_Accept" />
    <bpmn:sequenceFlow id="Flow_6_Yes" name="Sì" sourceRef="Gateway_Accept" targetRef="Event_SendPayment" />
    <bpmn:sequenceFlow id="Flow_6_No" name="No" sourceRef="Gateway_Accept" targetRef="Event_SendCancel" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Event_SendPayment" targetRef="Event_ReceiveShipment" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Event_SendCancel" targetRef="End_Customer_Cancel" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Event_ReceiveShipment" targetRef="Task_ReceiveGoods" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_ReceiveGoods" targetRef="End_Customer_Success" />
    <bpmn:intermediateThrowEvent id="Event_SendCancel" name="Annulla Ordine">
      <bpmn:incoming>Flow_6_No</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_CancelOrder" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="End_Customer_Cancel" name="Ordine Annullato">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Customer_Success" name="Ordine Completato">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ReceiveGoods" name="Ricevi Merce">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Event_ReceiveShipment" name="Attendi Spedizione">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ShipmentNotice" />
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmn:process id="Process_Seller" isExecutable="false">
    <bpmn:startEvent id="Event_ReceiveOrder" name="Ricevi Richiesta">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_OrderRequest" />
    </bpmn:startEvent>
    <bpmn:task id="Task_ValidateOrder" name="Valida Ordine">
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateThrowEvent id="Event_SendConfirmation" name="Invia Conferma">
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_OrderConfirmation" />
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="Task_ShipGoods" name="Spedisci Merce">
      <bpmn:incoming>Flow_S9</bpmn:incoming>
      <bpmn:outgoing>Flow_S10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Seller_Success" name="Ordine Evaso">
      <bpmn:incoming>Flow_S10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_S1" sourceRef="Event_ReceiveOrder" targetRef="Task_ValidateOrder" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="Task_ValidateOrder" targetRef="Task_CheckInventory" />
    <bpmn:sequenceFlow id="Flow_S3" sourceRef="Task_CheckInventory" targetRef="Event_SendConfirmation" />
    <bpmn:sequenceFlow id="Flow_S4" sourceRef="Event_SendConfirmation" targetRef="Task_ProcessOrder" />
    <bpmn:sequenceFlow id="Flow_S5" sourceRef="Task_ProcessOrder" targetRef="Event_ReceivePayment" />
    <bpmn:sequenceFlow id="Flow_S6" sourceRef="Event_ReceivePayment" targetRef="Task_VerifyPayment" />
    <bpmn:sequenceFlow id="Flow_S7" sourceRef="Task_VerifyPayment" targetRef="Task_PrepareShipment" />
    <bpmn:sequenceFlow id="Flow_S8" sourceRef="Task_PrepareShipment" targetRef="Event_SendShipment" />
    <bpmn:sequenceFlow id="Flow_S9" sourceRef="Event_SendShipment" targetRef="Task_ShipGoods" />
    <bpmn:sequenceFlow id="Flow_S10" sourceRef="Task_ShipGoods" targetRef="End_Seller_Success" />
    <bpmn:sequenceFlow id="Flow_S_Cancel" sourceRef="Boundary_CancelOrder" targetRef="Task_CancelOrder" />
    <bpmn:sequenceFlow id="Flow_S11" sourceRef="Task_CancelOrder" targetRef="End_Seller_Cancel" />
    <bpmn:task id="Task_CheckInventory" name="Verifica Disponibilità">
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Seller_Cancel" name="Ordine Annullato">
      <bpmn:incoming>Flow_S11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_CancelOrder" name="Annulla Ordine">
      <bpmn:incoming>Flow_S_Cancel</bpmn:incoming>
      <bpmn:outgoing>Flow_S11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProcessOrder" name="Elabora Ordine">
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Event_ReceivePayment" name="Attendi Pagamento">
      <bpmn:incoming>Flow_S5</bpmn:incoming>
      <bpmn:outgoing>Flow_S6</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_PaymentInfo" />
    </bpmn:intermediateCatchEvent>
    <bpmn:boundaryEvent id="Boundary_CancelOrder" name="Annullamento" attachedToRef="Task_ProcessOrder" cancelActivity="true">
      <bpmn:outgoing>Flow_S_Cancel</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0mo3rek" messageRef="Message_CancelOrder" />
    </bpmn:boundaryEvent>
    <bpmn:task id="Task_VerifyPayment" name="Verifica Pagamento">
      <bpmn:incoming>Flow_S6</bpmn:incoming>
      <bpmn:outgoing>Flow_S7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PrepareShipment" name="Prepara Spedizione">
      <bpmn:incoming>Flow_S7</bpmn:incoming>
      <bpmn:outgoing>Flow_S8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateThrowEvent id="Event_SendShipment" name="Notifica Spedizione">
      <bpmn:incoming>Flow_S8</bpmn:incoming>
      <bpmn:outgoing>Flow_S9</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_ShipmentNotice" />
    </bpmn:intermediateThrowEvent>
  </bpmn:process>
