        <dc:Bounds x="990" y="475" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SP_DenyAccess_di" bpmnElement="Task_SP_DenyAccess" bioc:stroke="#bdc3c7" color:border-color="#bdc3c7">
        <dc:Bounds x="990" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_SP_Success_di" bpmnElement="End_SP_Success">
        <dc:Bounds x="1152" y="497" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1129" y="533" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_SP_Failure_di" bpmnElement="End_SP_Failure">
        <dc:Bounds x="1152" y="612" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1130" y="648" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_SP_1_di" bpmnElement="Flow_SP_1">
        <di:waypoint x="268" y="515" />
        <di:waypoint x="320" y="515" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_2_di" bpmnElement="Flow_SP_2">
        <di:waypoint x="420" y="515" />
        <di:waypoint x="475" y="515" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_3_di" bpmnElement="Flow_SP_3">
        <di:waypoint x="525" y="515" />
        <di:waypoint x="990" y="515" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="752" y="490" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_4_di" bpmnElement="Flow_SP_4">
        <di:waypoint x="500" y="540" />
        <di:waypoint x="500" y="590" />
        <di:waypoint x="580" y="590" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="508" y="555" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_5_di" bpmnElement="Flow_SP_5">
        <di:waypoint x="680" y="590" />
        <di:waypoint x="730" y="590" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_6_di" bpmnElement="Flow_SP_6">
        <di:waypoint x="830" y="590" />
        <di:waypoint x="885" y="590" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_7_di" bpmnElement="Flow_SP_7">
        <di:waypoint x="910" y="565" />
        <di:waypoint x="910" y="515" />
        <di:waypoint x="990" y="515" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="920" y="530" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_8_di" bpmnElement="Flow_SP_8">
        <di:waypoint x="935" y="590" />
        <di:waypoint x="963" y="590" />
        <di:waypoint x="963" y="630" />
        <di:waypoint x="990" y="630" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="971" y="600" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_9_di" bpmnElement="Flow_SP_9">
        <di:waypoint x="1090" y="515" />
        <di:waypoint x="1152" y="515" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SP_10_di" bpmnElement="Flow_SP_10">
        <di:waypoint x="1090" y="630" />
        <di:waypoint x="1152" y="630" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_IdP_di" bpmnElement="Participant_IdP" isHorizontal="true">
        <dc:Bounds x="160" y="720" width="1300" height="230" />
      </bpmndi:BPMNShape>
