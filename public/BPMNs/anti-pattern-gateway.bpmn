      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="T3b_di" bpmnElement="T3b">
        <dc:Bounds x="420" y="830" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW3b_di" bpmnElement="GW3b" isMarkerVisible="true"
          bioc:stroke="#c0392b" color:border-color="#c0392b"
          bioc:fill="#fadbd8" color:background-color="#fadbd8">
        <dc:Bounds x="600" y="800" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="572" y="857" width="107" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="T3c_di" bpmnElement="T3c">
        <dc:Bounds x="710" y="785" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="E3_di" bpmnElement="E3">
        <dc:Bounds x="890" y="807" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="863" y="850" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Ann3_di" bpmnElement="Ann3">
        <dc:Bounds x="660" y="693" width="384" height="68" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="F3a_di" bpmnElement="F3a">
        <di:waypoint x="258" y="825" />
        <di:waypoint x="310" y="825" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="F3b_di" bpmnElement="F3b">
        <di:waypoint x="335" y="800" />
        <di:waypoint x="335" y="790" />
        <di:waypoint x="420" y="790" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="F3c_di" bpmnElement="F3c">
        <di:waypoint x="335" y="850" />
        <di:waypoint x="335" y="870" />
        <di:waypoint x="420" y="870" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="F3d_di" bpmnElement="F3d">
        <di:waypoint x="540" y="790" />
        <di:waypoint x="570" y="790" />
        <di:waypoint x="570" y="815" />
        <di:waypoint x="600" y="815" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="F3e_di" bpmnElement="F3e">
        <di:waypoint x="540" y="870" />
        <di:waypoint x="570" y="870" />
        <di:waypoint x="570" y="835" />
